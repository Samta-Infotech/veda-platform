# Cross-source golden set (Cross-source plan, Phase 6.1) — written against the ACTUAL
# ingested dummy corpus, not a hypothetical one. Sources:
#   2 homzhub (relational)   3 docs_contracts (filesystem)
#   4 invoices_csv (csv_lake: tables `maintenance`, `vendors`)
#   5 catalog_parquet (parquet: table `amenities_catalog`)
# Ground-truth cross-source joins (child@src -> parent@src):
#   maintenance.asset_id@4      -> assets_asset.id@2         (maintenance tickets -> assets)
#   vendors.city@4              -> assets_asset.city_name@2  (vendor city -> asset city)
#   amenities_catalog.amenity_name@5 -> assets_amenity.name@2 (catalog -> DB amenities)
#   doc amenity mentions (docx)@3    -> assets_amenity.name@2 (entity bridge)
# gold_columns / gold_tables use `table.col` / `table`; the eval normalizes to the
# trailing dotted components. gold_cross_source_edges are UNORDERED col-pairs with source.
# classes: federated_join | entity_bridge | doc_evidence | tabular | single_source | negative
{"query": "total maintenance amount spent per city where we own assets", "class": "federated_join", "intent": "federated", "expected_sources": ["invoices_csv", "homzhub"], "gold_tables": ["maintenance", "assets_asset"], "gold_columns": ["maintenance.amount", "maintenance.asset_id", "assets_asset.id", "assets_asset.city_name"], "gold_cross_source_edges": [{"a": "maintenance.asset_id@4", "b": "assets_asset.id@2"}], "note": "CSV×DB join on asset id, group by asset city"}
{"query": "list every maintenance ticket together with the asset it belongs to", "class": "federated_join", "intent": "federated", "expected_sources": ["invoices_csv", "homzhub"], "gold_tables": ["maintenance", "assets_asset"], "gold_columns": ["maintenance.ticket_id", "maintenance.asset_id", "maintenance.status", "assets_asset.id"], "gold_cross_source_edges": [{"a": "maintenance.asset_id@4", "b": "assets_asset.id@2"}], "note": "CSV×DB join, ticket to asset"}
{"query": "which vendors operate in cities where we have assets", "class": "federated_join", "intent": "federated", "expected_sources": ["invoices_csv", "homzhub"], "gold_tables": ["vendors", "assets_asset"], "gold_columns": ["vendors.city", "vendors.vendor_id", "assets_asset.city_name"], "gold_cross_source_edges": [{"a": "vendors.city@4", "b": "assets_asset.city_name@2"}], "note": "CSV×DB join on city name"}
{"query": "average vendor rating by city for the cities our assets are in", "class": "federated_join", "intent": "federated", "expected_sources": ["invoices_csv", "homzhub"], "gold_tables": ["vendors", "assets_asset"], "gold_columns": ["vendors.city", "vendors.rating", "assets_asset.city_name"], "gold_cross_source_edges": [{"a": "vendors.city@4", "b": "assets_asset.city_name@2"}], "note": "CSV×DB join on city, aggregate rating"}
{"query": "monthly fee for each catalog amenity that also exists in our asset amenities", "class": "federated_join", "intent": "federated", "expected_sources": ["catalog_parquet", "homzhub"], "gold_tables": ["amenities_catalog", "assets_amenity"], "gold_columns": ["amenities_catalog.amenity_name", "amenities_catalog.monthly_fee", "assets_amenity.name"], "gold_cross_source_edges": [{"a": "amenities_catalog.amenity_name@5", "b": "assets_amenity.name@2"}], "note": "parquet×DB join on amenity name"}
{"query": "which amenities in the catalog are not present in any of our asset amenities", "class": "federated_join", "intent": "federated", "expected_sources": ["catalog_parquet", "homzhub"], "gold_tables": ["amenities_catalog", "assets_amenity"], "gold_columns": ["amenities_catalog.amenity_name", "assets_amenity.name"], "gold_cross_source_edges": [{"a": "amenities_catalog.amenity_name@5", "b": "assets_amenity.name@2"}], "note": "parquet×DB anti-join on amenity name"}
{"query": "total maintenance spend broken down by amenity monthly fee band", "class": "federated_join", "intent": "federated", "expected_sources": ["invoices_csv", "catalog_parquet", "homzhub"], "gold_tables": ["maintenance", "amenities_catalog", "assets_amenity"], "gold_columns": ["maintenance.amount", "maintenance.asset_id", "amenities_catalog.amenity_name", "amenities_catalog.monthly_fee", "assets_amenity.name"], "gold_cross_source_edges": [{"a": "maintenance.asset_id@4", "b": "assets_asset.id@2"}, {"a": "amenities_catalog.amenity_name@5", "b": "assets_amenity.name@2"}], "note": "three-source federated join"}
{"query": "which amenities mentioned in the maintenance policy document exist in our asset amenities", "class": "entity_bridge", "intent": "federated", "expected_sources": ["docs_contracts", "homzhub"], "gold_tables": ["assets_amenity"], "gold_columns": ["assets_amenity.name"], "gold_entities": ["football", "basket ball", "squash", "intercom", "grocery store", "green building"], "note": "doc→DB entity bridge on amenity names"}
{"query": "does the green tower master service agreement reference any amenities we track in our system", "class": "entity_bridge", "intent": "federated", "expected_sources": ["docs_contracts", "homzhub"], "gold_tables": ["assets_amenity"], "gold_columns": ["assets_amenity.name"], "gold_entities": ["green building", "tower"], "note": "PDF→DB entity bridge"}
{"query": "what cities are named in our site notes and do we hold assets there", "class": "entity_bridge", "intent": "federated", "expected_sources": ["docs_contracts", "homzhub"], "gold_tables": ["generics_city", "generics_location", "assets_asset"], "gold_columns": ["generics_city.name", "generics_location.city_name", "assets_asset.city_name"], "gold_entities": ["kochi"], "note": "doc→DB entity bridge on city"}
