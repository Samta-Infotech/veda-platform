{"query": "show maintenance tickets with amount and status", "class": "tabular", "intent": "sql", "expected_sources": ["invoices_csv"], "gold_tables": ["maintenance"], "gold_columns": ["maintenance.ticket_id", "maintenance.amount", "maintenance.status"], "note": "single-source csv tabular read"}
{"query": "list all asset amenities we have on record", "class": "single_source", "intent": "sql", "expected_sources": ["homzhub"], "gold_tables": ["assets_amenity"], "gold_columns": ["assets_amenity.name", "assets_amenity.id"], "note": "homzhub-only scoping sanity"}
{"query": "join maintenance ticket ids to vendor ids", "class": "negative", "intent": "sql", "expected_sources": ["invoices_csv"], "gold_tables": ["maintenance", "vendors"], "gold_columns": [], "must_not_link": [{"a": "maintenance.ticket_id@4", "b": "vendors.ticket_id@4"}, {"a": "maintenance.asset_id@4", "b": "assets_asset.block_number@2"}], "note": "negative: internal ticket ids must NOT be a cross-source join key to homzhub ids"}
{"query": "are amenity categories in the catalog the same as generic list-of-value categories in the database", "class": "negative", "intent": "sql", "expected_sources": ["catalog_parquet", "homzhub"], "gold_tables": [], "gold_columns": [], "must_not_link": [{"a": "amenities_catalog.category@5", "b": "list_of_values_listofvalue.code@2"}], "note": "negative: generic 'category' overlap must NOT emit a HIGH cross-source edge"}
