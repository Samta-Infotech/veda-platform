# VEDA platform — example environment (migration_plan.md §9). NO real secrets here.
# Copy to .env and fill. Secrets in prod come from Docker secrets, not this file.

# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-prod
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Postgres (reached THROUGH PgBouncer, never directly) — §1.1, §3 ──────────
POSTGRES_DB=veda
POSTGRES_USER=veda
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# App DB aliases connect here (transaction pooling):
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
# Optional separate source-registry DB alias:
SOURCE_REGISTRY_DB=veda

# ── Redis — TWO instances in prod (§1.2, §3) ─────────────────────────────────
# Broker: unbounded, never evicts.
REDIS_BROKER_URL=redis://redis-broker:6379/0
# Cache: maxmemory + allkeys-lru; hot indices + retrieval memo + rehydrate pub/sub.
REDIS_CACHE_URL=redis://redis-cache:6379/0

# ── SLM backend seam (§8b) ───────────────────────────────────────────────────
# worker/dev → ollama ; inference (prod) → vllm
SLM_BACKEND=ollama
SLM_MODEL_NAME=qwen2.5-coder:7b
OLLAMA_URL=http://ollama:11434
VLLM_URL=http://vllm:8000/v1
# Optional override: classify/smalltalk/follow-up-resolution are conversational
# judgment calls, not code generation, so they can use a small INSTRUCT model
# instead of SLM_MODEL_NAME's CODER model. Falls back to SLM_MODEL_NAME if unset.
CHATBOT_CLASSIFY_MODEL=qwen2.5:7b-instruct

# ── Engine flags (VEDA_* override config.py via the settings bridge, §9) ─────
VEDA_ENCODER_MODE=ensemble
VEDA_TOP_K=15
VEDA_TOP_K_TO_LLM=6
VEDA_QUERY_ROUTER_ENABLED=true
VEDA_IR_JOIN_FREE_ENABLED=true
VEDA_FAST_PATH_ENABLED=true
VEDA_QUERY_DECOMPOSE_ENABLED=false
# Insight Engine (query/result_explainer.py::run_insight_engine — narrative
# insights + follow_up_questions, NL_SUMMARY_MODEL). No VEDA_ prefix: config.py
# reads this one directly, not through the VEDA_* settings bridge above.
# Off by default in config.py — a new, best-effort layer that must be
# explicitly opted into per deployment before it can affect the response
# shape. Set to true only when ready to opt in.
INSIGHT_ENGINE_ENABLED=true
# Follow-up-question surfacing (2026-07-16, parked): the grounding/validation
# code (query/result_explainer.py::validate_follow_up_questions) stays active
# regardless, this only gates whether follow_up_questions ever reaches the
# client. Only meaningful when INSIGHT_ENGINE_ENABLED=true.
INSIGHT_FOLLOW_UPS_ENABLED=false
# Timeout for the single combined insight-engine SLM call (summary + insights +
# visualization suggestion + follow-ups). REALITY CHECK (2026-07-20, measured on
# the live remote Ollama / qwen2.5:7b-instruct): generation runs ~21 tokens/sec,
# so the ~280-token insight output takes ~13-15s — the old 10000 timed out on
# EVERY analytical query and fell back to the deterministic answer. Bumped to
# 25000 for real headroom. If summaries still time out under load, either raise
# this further or switch NL_SUMMARY_MODEL to a smaller/faster model.
INSIGHT_ENGINE_TIMEOUT_MS=25000

# ── Result summarization (query/result_explainer.py::run_nl_answer) ──────────
# Upgraded 2026-07-17: qwen2.5:1.5b-instruct -> qwen2.5:7b-instruct — the summary
# now weaves in verified findings (leaders/laggards, spread, distribution) and the
# 1.5B produced thin/uneven prose for that. Trade-off: SLOW — measured ~21 tok/s on
# the live remote Ollama, so a full analytical summary takes ~13-15s (hence the
# 25000 timeouts below). If that latency is unacceptable, switch back to
# qwen2.5:1.5b-instruct (much faster, ~4x; slightly thinner prose but it only
# NARRATES precomputed findings, so quality loss is small).
NL_SUMMARY_MODEL=qwen2.5:7b-instruct
# Same reality as INSIGHT_ENGINE_TIMEOUT_MS: at ~21 tok/s the 7B model needs
# ~13-15s for a full analytical summary (up to NL_SUMMARY_ANALYTICAL_MAX_TOKENS),
# so 10000 timed out. Raised to 25000. (Env overrides config.py's default.)
NL_SUMMARY_TIMEOUT_MS=25000
# Completion budget for a BRIEF (scalar/detail) summary. Analytical (grouped/
# ranked/trend) results get NL_SUMMARY_ANALYTICAL_MAX_TOKENS instead — the summary
# is evidence-adaptive (result_explainer._summary_mode), not one-size-fits-all.
NL_SUMMARY_MAX_TOKENS=160
# Larger completion budget for an ANALYTICAL summary (leaders/laggards, spread,
# distribution, trends woven in). Depth is driven by verified findings, not padding.
NL_SUMMARY_ANALYTICAL_MAX_TOKENS=320
# Max verified deterministic findings handed to the analytical summary (brief uses 2).
NL_SUMMARY_MAX_FINDINGS=5
# Anti-hallucination guardrail: after the summary SLM answers, every number it
# states must be traceable to the precomputed facts/metrics/patterns (±2%
# tolerance) or it's discarded in favor of the deterministic fallback answer —
# a plainer-but-correct summary beats a confident wrong number. Toggle off
# here if it ever over-rejects in the field. NOTE: only checks NUMBERS — it does
# not catch qualitative claims ("about three times").
NL_SUMMARY_NUMERIC_GUARD=true

# ── Post-execution analysis + semantic validation (result_analyzer / semantic_validation) ──
# Scalability + population-consistency bound: pattern stats AND the summary's numeric
# aggregates both scan at most this many rows (same bound in both, so a "vs average X"
# pattern is never mixed with a full-result mean). row_count reported to the user is
# always the TRUE total; only the analysis scan is bounded. Generous default — typical
# results are fully scanned.
ANALYSIS_MAX_ROWS=50000
# Shared analytical-semantics validation (operator preserved / group-by present /
# user-facing dimension not an unnecessary identifier / joins grounded), run on every
# path's generated SQL (Tier-1 LLM branch, Tier-2, LangGraph). ENABLED = record findings
# to the trace (advisory, no behavior change). ENFORCE = let a hard operator-loss finding
# drive the existing repair/retry loop — keep OFF until validated on live models.
SEMANTIC_VALIDATION_ENABLED=true
SEMANTIC_VALIDATION_ENFORCE=false

# ── HNSW params — the tuned parity config is a setting, not a magic number (§7.1a) ──
VEDA_HNSW_M=16
VEDA_HNSW_EF_CONSTRUCTION=200
VEDA_HNSW_EF_SEARCH=40

# ── Inference tier ───────────────────────────────────────────────────────────
# Derive from MEASURED per-worker RSS, not CPU count (§8.1).
INFERENCE_WORKERS=1
MODEL_CACHE_DIR=/models
# Zero-egress: startup must never reach the network.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# --- engine internal store (separate DB; avoids collision with Django's substrate tables) ---
VEDA_INTERNAL_HOST=pgbouncer
VEDA_INTERNAL_PORT=6432
VEDA_INTERNAL_DBNAME=veda_engine
VEDA_INTERNAL_USER=veda
VEDA_INTERNAL_PASSWORD=change-me
# --- client SOURCE DB connections are NOT configured here (§3.1). ---
# The DB `Source` row (apps.sources) is the single source of truth. The ingesting
# worker serializes THIS source's connection into VEDA_SOURCE_JSON / VEDA_SOURCE_*
# env from the table at job time — never from a static .env value. There are no
# hardcoded source hosts or credentials anywhere.

# api → inference service
INFERENCE_URL=http://inference:8001
INFERENCE_TIMEOUT_S=300

# LLM queries on CPU are slow — allow long worker timeout
GUNICORN_TIMEOUT=600

# ── MLflow observability (docker-compose.mlflow.yml) ─────────────────────────
# Host port for the MLflow UI (experiment VEDA-Query-Observability). Default
# changed from 5000 -> 5001: macOS's AirPlay Receiver squats on 5000.
MLFLOW_UI_PORT=5001
