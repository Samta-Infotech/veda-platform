veda_core/schema/*.pkl
parity_baseline.json

# Per-source ingestion artifact dumps (semantic model / graphs / concepts / etc.).
# These are generated by ingestion and can be tens of MB — kept on disk for the
# running app, but never committed (PR #5 accidentally committed ~21 MB of these).
default_db/
homzhub/

# Runtime query logs (explain trace / route log) — process output, not source.
veda_core/logs/

